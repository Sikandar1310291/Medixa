<UserControl x:Class="PharmaBilling.Source.Views.SaleTabsUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F4F4">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Orientation="Horizontal" Margin="10,10,10,0">
            <Button Content="+ NEW SALE TAB" Click="AddNewTab_Click" Background="#27AE60" Foreground="White" Padding="15,8" FontWeight="Bold" Cursor="Hand"/>
            <TextBlock Text="Tip: Open a new tab to temporarily hold current bill!" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="Gray" FontStyle="Italic"/>
        </StackPanel>
        
        <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="10" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="Margin" Value="0,0,5,0"/>
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="BorderBrush" Value="#CCC"/>
                    <Setter Property="BorderThickness" Value="1,1,1,0"/>
                </Style>
            </TabControl.Resources>
        </TabControl>
    </Grid>
</UserControl>
