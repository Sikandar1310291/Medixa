<Window x:Class="PharmaBilling.Source.Views.NetworkConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Network Connection Setup" Width="480" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Background="#F8F9FA" WindowStyle="ToolWindow">
        
    <Border BorderThickness="1" BorderBrush="#DEE2E6" Background="White" Margin="15" CornerRadius="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Color="LightGray" Opacity="0.3" ShadowDepth="2"/>
        </Border.Effect>
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="LAN Configuration Setup" FontSize="22" FontWeight="Black" Foreground="#2C3E50" Margin="0,0,0,5"/>
            <TextBlock Grid.Row="1" Text="Specify this terminal's Network Role instantly below." TextWrapping="Wrap" Foreground="#7F8C8D" Margin="0,0,0,25" FontSize="13"/>

            <GroupBox Grid.Row="2" Header="  Terminal Operating Role  " Padding="15" BorderBrush="#BDC3C7" Margin="0,0,0,20" Foreground="#2980B9" FontWeight="Bold" FontSize="14">
                <StackPanel>
                    <RadioButton x:Name="rbServer" Content="SERVER (This computer physically holds the SQLite DB)"
                                 FontSize="13" FontWeight="SemiBold" Margin="0,10,0,15" Checked="OperatingMode_Changed" Foreground="#2C3E50" Cursor="Hand"/>
                    <RadioButton x:Name="rbClient" Content="CLIENT (Cashier Terminal connected via Wi-Fi/LAN)"
                                 FontSize="13" FontWeight="SemiBold" Margin="0,5,0,5" Checked="OperatingMode_Changed" Foreground="#7F8C8D" Cursor="Hand"/>
                </StackPanel>
            </GroupBox>

            <Border x:Name="brdClientSettings" Grid.Row="3" Background="#F1F3F5" CornerRadius="6" BorderBrush="#E9ECEF" BorderThickness="1" Margin="0,0,0,20" Visibility="Collapsed">
                <StackPanel Margin="15">
                    <TextBlock Text="Primary Server IP Address (e.g., 192.168.0.100)" Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#343A40"/>
                    <TextBox x:Name="txtServerIP" Height="35" Margin="0,0,0,15" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#CED4DA">
                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></TextBox.Resources>
                    </TextBox>
                    
                    <TextBlock Text="Shared Network Folder Name" Margin="0,0,0,8" FontWeight="SemiBold" Foreground="#343A40"/>
                    <TextBox x:Name="txtSharedFolder" Height="35" Margin="0,0,0,10" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#CED4DA" Text="Database">
                        <TextBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></TextBox.Resources>
                    </TextBox>
                    <Button Content="🔍 Test Connection" Height="35" Background="#2196F3" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="TestConnection_Click" Cursor="Hand" HorizontalAlignment="Left" Padding="15,0">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                    </Button>
                </StackPanel>
            </Border>
            
            <!-- Only visible when Server Mode is set -->
            <Border x:Name="brdServerSettings" Grid.Row="4" Background="#E8F5E9" CornerRadius="6" BorderBrush="#A5D6A7" BorderThickness="1" Margin="0,0,0,20">
                <StackPanel Margin="15">
                    <TextBlock Text="✅ SERVER MODE ACTIVE" Foreground="#2E7D32" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                    <TextBlock Text="This PC's IP (tell this to Client PCs):" FontWeight="SemiBold" Foreground="#1B5E20" Margin="0,0,0,4"/>
                    <TextBlock x:Name="txtThisIP" Text="Detecting..." FontSize="18" FontWeight="Black" Foreground="#1565C0" Margin="0,0,0,10"/>
                    <TextBlock Text="Clients must set their Network Setup IP to the address shown above." TextWrapping="Wrap" Foreground="#388E3C" FontSize="12"/>
                    <TextBlock Text="Database stored in: C:\ProgramData\Medixa\PharmaDB.sqlite" Foreground="#616161" FontSize="11" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Save Setup" Width="140" Height="42" Background="#27AE60" Foreground="White" FontWeight="ExtraBold" BorderThickness="0" Margin="0,0,10,0" Click="Save_Click" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></Button.Resources>
                </Button>
                <Button Content="Cancel" Width="100" Height="42" Background="#DEE2E6" Foreground="#495057" FontWeight="Bold" BorderThickness="0" Click="Cancel_Click" Cursor="Hand">
                    <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="5"/></Style></Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
