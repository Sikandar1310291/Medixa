<UserControl x:Class="PharmaBilling.Source.Views.StockUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">

    <UserControl.Resources>

        <!-- ── Shared Button Template ── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#1C6EA4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#C0392B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#EBF5FB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid header style -->
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EAECEE"/>
            <Setter Property="Height" Value="42"/>
        </Style>

        <!-- DataGrid cell style -->
        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="10,0" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- Root: a Grid so we can overlay the Edit Panel -->
    <Grid Background="#F4F7F6">

        <!-- ══════════════════ MAIN CONTENT ══════════════════ -->
        <Grid x:Name="mainContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- top bar -->
                <RowDefinition Height="Auto"/>
                <!-- KPI summary strip -->
                <RowDefinition Height="*"/>
                <!-- data grid -->
            </Grid.RowDefinitions>

            <!-- ── TOP BAR ── -->
            <Border Grid.Row="0" Background="White" Padding="20,14"
                    BorderBrush="#EAECEE" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📦  Available Stock" FontSize="18"
                                   FontWeight="Bold" Foreground="#1A1A2E"
                                   VerticalAlignment="Center"/>
                        <Border Background="#E8F8F5" CornerRadius="12" Margin="14,0,0,0"
                                Padding="10,3" VerticalAlignment="Center">
                            <TextBlock x:Name="lblTotalBadge" Text="0 batches"
                                       Foreground="#1ABC9C" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>

                    <!-- Search -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Border Background="#F8F9F9" BorderBrush="#D5DBDB"
                                BorderThickness="1" CornerRadius="20"
                                Padding="14,0" Height="38" Margin="0,0,10,0">
                            <Grid Width="240">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔍" Foreground="#95A5A6"
                                           VerticalAlignment="Center" Margin="0,0,8,0" FontSize="13"/>
                                <TextBox Grid.Column="1" x:Name="txtSearch"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="#2C3E50" VerticalAlignment="Center"
                                         FontSize="13" VerticalContentAlignment="Center"
                                         KeyUp="TxtSearch_KeyUp"/>
                                <TextBlock Grid.Column="1" Text="Search medicine name…"
                                           Foreground="#BDC3C7" VerticalAlignment="Center"
                                           IsHitTestVisible="False" FontSize="13">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- Clear button -->
                                <Button Grid.Column="2" x:Name="btnClear" Content="✕"
                                        Background="Transparent" BorderThickness="0"
                                        Foreground="#95A5A6" Cursor="Hand" FontSize="11"
                                        Click="BtnClear_Click" Padding="4,0" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <Button Content="🔄  Refresh" Style="{StaticResource PrimaryBtn}"
                                Background="#34495E" Click="BtnRefresh_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ── KPI STRIP ── -->
            <Border Grid.Row="1" Background="White" Padding="20,10"
                    BorderBrush="#EAECEE" BorderThickness="0,0,0,1" Margin="0,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <!-- Total SKUs -->
                    <Border Background="#EEF4FE" CornerRadius="8" Padding="16,8" Margin="0,0,12,0"
                            BorderBrush="#BBDEFB" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💊" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="Unique Medicines" Foreground="#1565C0" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock x:Name="lblUniqueMeds" Text="0" FontSize="20" FontWeight="Bold" Foreground="#0D47A1"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Total Units -->
                    <Border Background="#EEF9F0" CornerRadius="8" Padding="16,8" Margin="0,0,12,0"
                            BorderBrush="#C8E6C9" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="Total Units" Foreground="#388E3C" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock x:Name="lblTotalUnits" Text="0" FontSize="20" FontWeight="Bold" Foreground="#1B5E20"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Stock Value -->
                    <Border Background="#FFF8E1" CornerRadius="8" Padding="16,8"
                            BorderBrush="#FFE082" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💰" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="Inventory Value (TP)" Foreground="#E65100" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock x:Name="lblStockValue" Text="Rs. 0" FontSize="20" FontWeight="Bold" Foreground="#BF360C"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── DATA GRID ── -->
            <Border Grid.Row="2" Background="White" CornerRadius="8" Margin="20" Padding="5">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Direction="270" Color="Black" Opacity="0.05"/>
                </Border.Effect>

                <DataGrid x:Name="dgStock"
                          Margin="5"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          Background="White"
                          BorderThickness="0"
                          RowHeight="44"
                          AlternatingRowBackground="#FAFBFC"
                          EnableRowVirtualization="True"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          ScrollViewer.CanContentScroll="True"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ColumnHeaderStyle="{StaticResource DgHeader}"
                          CellStyle="{StaticResource DgCell}">

                    <DataGrid.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#EBF5FB"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#2C3E50"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#F4F6F6"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#2C3E50"/>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"            Binding="{Binding RowNo}"       Width="44"/>
                        <DataGridTextColumn Header="Medicine Name" Binding="{Binding MedicineName}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Foreground" Value="#2C3E50"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Type"         Binding="{Binding Type}"        Width="90"/>
                        <DataGridTextColumn Header="Batch"        Binding="{Binding BatchNo}"     Width="110"/>
                        <DataGridTextColumn Header="Rack"         Binding="{Binding RackNo}"      Width="80"/>
                        <DataGridTextColumn Header="Expiry"       Binding="{Binding ExpiryDate}"  Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#2C3E50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ExpiryStatus}" Value="Expired">
                                            <Setter Property="Foreground" Value="#E74C3C"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ExpiryStatus}" Value="Soon">
                                            <Setter Property="Foreground" Value="#E67E22"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Units — highlighted prominently -->
                        <DataGridTextColumn Header="Units Available" Binding="{Binding Quantity}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="FontSize" Value="14"/>
                                    <Setter Property="Foreground" Value="#27AE60"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="TP (Rs.)"     Binding="{Binding PurchasePrice, StringFormat=N2}" Width="100"/>
                        <DataGridTextColumn Header="Retail (Rs.)" Binding="{Binding SalePrice,    StringFormat=N2}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#2980B9"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Actions -->
                        <DataGridTemplateColumn Header="Actions" Width="130">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Button Content="✏️ Edit" Click="EditStock_Click"
                                                Style="{StaticResource GhostBtn}"
                                                Foreground="#2980B9" Margin="0,0,6,0"/>
                                        <Button Content="🗑 Del" Click="DeleteStock_Click"
                                                Style="{StaticResource GhostBtn}"
                                                Foreground="#E74C3C"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <!-- ══════════════════ EDIT OVERLAY ══════════════════ -->
        <Grid x:Name="editOverlay" Visibility="Collapsed" Background="#80000000">
            <Border Width="460" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="White" CornerRadius="12" Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Color="Black" Opacity="0.25"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="✏️  Edit Stock Batch" FontSize="18" FontWeight="Bold"
                               Foreground="#1A1A2E" Margin="0,0,0,20"/>

                    <!-- Medicine Name (read-only) -->
                    <TextBlock Text="Medicine" Foreground="#7F8C8D" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtEditMedName" IsReadOnly="True"
                             Background="#F4F6F6" BorderBrush="#EAECEE" BorderThickness="1"
                             Padding="10,8" FontSize="13" Foreground="#555" Margin="0,0,0,14"/>

                    <!-- Batch No -->
                    <TextBlock Text="Batch Number" Foreground="#7F8C8D" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtEditBatch"
                             Background="White" BorderBrush="#D5DBDB" BorderThickness="1"
                             Padding="10,8" FontSize="13" Foreground="#2C3E50" Margin="0,0,0,14"/>

                    <!-- Rack -->
                    <TextBlock Text="Rack Number" Foreground="#7F8C8D" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtEditRack"
                             Background="White" BorderBrush="#D5DBDB" BorderThickness="1"
                             Padding="10,8" FontSize="13" Foreground="#2C3E50" Margin="0,0,0,14"/>

                    <!-- Expiry Date -->
                    <TextBlock Text="Expiry Date (YYYY-MM-DD)" Foreground="#7F8C8D" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtEditExpiry"
                             Background="White" BorderBrush="#D5DBDB" BorderThickness="1"
                             Padding="10,8" FontSize="13" Foreground="#2C3E50" Margin="0,0,0,14"/>

                    <!-- Quantity -->
                    <TextBlock Text="Units / Quantity" Foreground="#7F8C8D" FontSize="11"
                               FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtEditQty"
                             Background="White" BorderBrush="#D5DBDB" BorderThickness="1"
                             Padding="10,8" FontSize="16" FontWeight="Bold"
                             Foreground="#27AE60" Margin="0,0,0,24"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Width="100" Height="38" Margin="0,0,10,0"
                                Background="#ECF0F1" Foreground="#555" BorderThickness="0"
                                Cursor="Hand" Click="CancelEdit_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="b" CornerRadius="6"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="b" Property="Background" Value="#D5D8DC"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="💾  Save Changes" Width="150" Height="38"
                                Style="{StaticResource PrimaryBtn}" Click="SaveEdit_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>
