<UserControl x:Class="PharmaBilling.Source.Views.SaleUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F4F4">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER SECTION -->
        <Border Grid.Row="0" BorderBrush="#CCC" BorderThickness="1" Background="White" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,15,5">
                    <TextBlock Text="Doc #" Foreground="Gray" FontSize="10"/>
                    <TextBox Text="{Binding DocNo}" Width="80" IsReadOnly="True" Background="#EEE"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,15,5">
                    <TextBlock Text="Sale Date" Foreground="Gray" FontSize="10"/>
                    <DatePicker SelectedDate="{Binding SaleDate}" Width="120"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,15,5">
                    <TextBlock Text="Bill #" Foreground="Gray" FontSize="10"/>
                    <TextBox Text="{Binding BillNo}" Width="100"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="3" Margin="0,0,15,5">
                    <TextBlock Text="Type" Foreground="Gray" FontSize="10"/>
                    <ComboBox ItemsSource="{Binding SaleTypes}" SelectedItem="{Binding SaleType}" Width="100"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,0,15,5">
                    <TextBlock Text="Cash Party Name" Foreground="Gray" FontSize="10"/>
                    <TextBox x:Name="txtCashPartyName" Text="{Binding CashPartyName}"/>
                </StackPanel>

                <!-- Search Item button -->
                <StackPanel Grid.Row="0" Grid.Column="5" VerticalAlignment="Bottom" Margin="0,0,8,5">
                    <Button x:Name="btnSearchItem" Content="SEARCH ITEM (Ctrl+F)" Background="#3498DB"
                            Foreground="White" Padding="10,5" Click="btnSearchItem_Click"/>
                </StackPanel>

                <!-- Sale Return button -->
                <StackPanel Grid.Row="0" Grid.Column="6" VerticalAlignment="Bottom" Margin="0,0,0,5">
                    <Button x:Name="btnSaleReturn" Content="↩ Sale Return" Background="#E67E22"
                            Foreground="White" Padding="10,5" FontWeight="Bold"
                            Cursor="Hand" Click="btnSaleReturn_Click"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="6" Margin="0,5,15,0">
                    <TextBlock Text="Remarks" Foreground="Gray" FontSize="10"/>
                    <TextBox Text="{Binding Remarks}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN BODY SECTION -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: GRID SECTION -->
            <DataGrid EnableRowVirtualization="True" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling" ScrollViewer.CanContentScroll="True" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" x:Name="dgSaleItems" Grid.Column="0" ItemsSource="{Binding SaleItems}" SelectedItem="{Binding SelectedSaleItem}" AutoGenerateColumns="False"
                      CanUserAddRows="False" Background="White" BorderBrush="#CCC" BorderThickness="1"
                      RowHeaderWidth="20" GridLinesVisibility="All" Margin="0,0,10,5"
                      AlternatingRowBackground="#F9F9F9">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Item Name" Binding="{Binding MedicineName}" IsReadOnly="True" Width="*"/>
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity, UpdateSourceTrigger=LostFocus}" Width="55"/>
                    <DataGridTextColumn Header="TP (Unit)" Binding="{Binding TP, StringFormat=N2}" IsReadOnly="True" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#C0392B"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="5,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Retail (Box)" Binding="{Binding Retail, StringFormat=N2}" IsReadOnly="True" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#7F8C8D"/>
                                <Setter Property="FontStyle" Value="Italic"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=N2, UpdateSourceTrigger=LostFocus}" Width="90"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding TotalPrice, StringFormat=N2}" IsReadOnly="True" Width="90">
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Width="50">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" Foreground="Red" Click="RemoveItem_Click"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- RIGHT: SIDE PANEL SECTION -->
            <Border Grid.Column="1" BorderBrush="#CCC" BorderThickness="1" Background="White" Padding="15" Margin="0,0,0,5" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#2ECC71" Padding="10" CornerRadius="4" Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Available Stock:" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding SelectedStock}" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Row="1" Background="#E74C3C" Padding="10" CornerRadius="4" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="Balanced Stock:" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>
                            <TextBlock Text="{Binding BalancedStock}" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Gross Amount:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                <TextBox Text="{Binding GrossTotal, StringFormat=N2}" Grid.Row="0" Grid.Column="1" IsReadOnly="True" HorizontalContentAlignment="Right" Margin="0,0,0,5"/>

                                <TextBlock Text="Discount %:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                <TextBox x:Name="txtDiscount" Text="{Binding DiscountPercent}" Grid.Row="1" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,0,0,5"/>

                                <TextBlock Text="GST %:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                <TextBox Text="{Binding TaxPercent}" Grid.Row="2" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,0,0,5"/>

                                <TextBlock Text="Grand Total:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,5" FontWeight="Bold" FontSize="14"/>
                                <TextBox Text="{Binding GrandTotal, StringFormat=N2}" Grid.Row="3" Grid.Column="1" IsReadOnly="True" HorizontalContentAlignment="Right" FontWeight="Bold" Background="#FADBD8" FontSize="14" Margin="0,0,0,5"/>

                                <TextBlock Text="Cash Received:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,5"/>
                                <TextBox x:Name="txtCashReceived" Text="{Binding CashReceived, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1" HorizontalContentAlignment="Right" Margin="0,0,0,5"/>

                                <TextBlock Text="Balance:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold" FontSize="14"/>
                                <TextBox Text="{Binding Balance, StringFormat=N2}" Grid.Row="5" Grid.Column="1" IsReadOnly="True" HorizontalContentAlignment="Right" FontWeight="Bold" Background="#D5F5E3" FontSize="14"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- BUTTONS SECTION -->
                    <StackPanel Grid.Row="3" HorizontalAlignment="Stretch" Margin="0,10,0,0">
                        <Button Content="Save Draft" Height="35" Margin="0,0,0,5" Background="#BDC3C7" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="btnSaveDraft_Click"/>
                        <Button x:Name="btnPrintSave" Content="Print &amp; Save Invoice (Ctrl+Enter)" Height="45" Background="#2980B9" Foreground="White" FontWeight="Bold" FontSize="14" BorderThickness="0" Click="btnPrintSave_Click" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
