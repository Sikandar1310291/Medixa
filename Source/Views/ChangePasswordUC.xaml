<UserControl x:Class="PharmaBilling.Source.Views.ChangePasswordUC"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           
         >
    <Grid Background="White">
        <StackPanel Margin="30">
            <TextBlock Text="Change Password" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <TextBlock Text="Current Password" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtCurrentPass"  Margin="0,0,0,15" VerticalContentAlignment="Center"/>
            
            <TextBlock Text="New Password" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtNewPass"  Margin="0,0,0,15" VerticalContentAlignment="Center"/>
            
            <TextBlock Text="Confirm Password" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtConfirmPass"  Margin="0,0,0,25" VerticalContentAlignment="Center"/>
            
            <Button x:Name="btnSave" Content="Save Password"  Background="#1976D2" Foreground="White" FontWeight="Bold" Click="btnSave_Click"/>
        </StackPanel>
    </Grid>
</UserControl>
