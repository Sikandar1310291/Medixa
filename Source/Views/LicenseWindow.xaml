<Window x:Class="PharmaBilling.Source.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Medixa - SaaS License Activation" Height="500" Width="550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F7FA" FontFamily="Inter, Segoe UI, sans-serif">
    <Grid>
        <!-- Background Banner -->
        <Border Height="180" VerticalAlignment="Top" Background="#2C3E50" />
        
        <StackPanel Margin="30">
            <!-- Icon / Logo Area -->
            <Ellipse Width="70" Height="70" Fill="#27AE60" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Medixa SaaS Activation" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
            <TextBlock Text="Enter your cloud license key to continue using the software." FontSize="14" Foreground="#BDC3C7" HorizontalAlignment="Center" Margin="0,5,0,0"/>

            <!-- Form Card -->
            <Border Background="White" CornerRadius="12" Margin="0,30,0,0" Padding="30"
                    BorderThickness="1" BorderBrush="#E0E6ED">
                <Border.Effect>
                    <DropShadowEffect Direction="270" ShadowDepth="5" BlurRadius="15" Opacity="0.1" Color="Black"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="License Key" FontSize="14" FontWeight="SemiBold" Foreground="#34495E" Margin="0,0,0,8"/>
                    
                    <TextBox x:Name="txtLicenseKey" Height="45" FontSize="16" Padding="10,0"
                             BorderBrush="#BDC3C7" BorderThickness="1.5" Foreground="#2C3E50"
                             VerticalContentAlignment="Center" Background="#F8FAFC">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock x:Name="lblStatus" Foreground="#E74C3C" FontSize="13" Margin="0,10,0,0" 
                               TextWrapping="Wrap" HorizontalAlignment="Center" FontWeight="Medium"/>

                    <Button x:Name="btnActivate" Content="VERIFY SERVER LICENSE" Height="45" Margin="0,20,0,0"
                            Background="#27AE60" Foreground="White" FontSize="14" FontWeight="Bold"
                            Cursor="Hand" IsDefault="True" Click="btnActivate_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="22">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
            
            <TextBlock Text="Powered by Apexora AI Cloud" FontSize="12" Foreground="#95A5A6" HorizontalAlignment="Center" Margin="0,20,0,0"/>
        </StackPanel>
    </Grid>
</Window>
