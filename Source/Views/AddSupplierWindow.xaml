<Window x:Class="PharmaBilling.Source.Views.AddSupplierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Supplier Details" SizeToContent="Height" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#FAFAFA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitle" Text="Supplier Details" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#34495E"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Supplier Name *" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#7F8C8D"/>
            <TextBox x:Name="txtName" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center" BorderBrush="#BDC3C7"/>

            <TextBlock Text="Contact No." Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#7F8C8D"/>
            <TextBox x:Name="txtContact" Text="{Binding Contact, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center" BorderBrush="#BDC3C7"/>

            <TextBlock Text="Email Address" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#7F8C8D"/>
            <TextBox x:Name="txtEmail" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center" BorderBrush="#BDC3C7"/>

            <TextBlock Text="Physical Address" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#7F8C8D"/>
            <TextBox x:Name="txtAddress" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15" BorderBrush="#BDC3C7"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save Supplier" Width="110" Height="35" Background="#27AE60" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Click="Save_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="90" Height="35" Background="#BDC3C7" Foreground="Black" BorderThickness="0" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
