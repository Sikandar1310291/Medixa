<Window x:Class="PharmaBilling.Source.Views.AddMedicineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Medicine" Height="550" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#FAFAFA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitle" Text="Medicine Details" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#34495E"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Medicine Name" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#7F8C8D"/>
                <TextBox x:Name="txtName" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center" BorderBrush="#BDC3C7"/>

                <TextBlock Text="Type (Tab/Syp/Cap)" Margin="0,5,0,2" FontWeight="SemiBold" Foreground="#7F8C8D"/>
                <ComboBox x:Name="cmbType" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center">
                    <ComboBoxItem Content="Tablet"/>
                    <ComboBoxItem Content="Syrup"/>
                    <ComboBoxItem Content="Capsule"/>
                    <ComboBoxItem Content="Injection"/>
                    <ComboBoxItem Content="Other"/>
                </ComboBox>

                <!-- New Abuzar Parity Fields -->
                <TextBlock Text="Barcode (Scan or Type)" Margin="0,5,0,2"/>
                <TextBox x:Name="txtBarcode" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center" Background="#FAFAFA" BorderBrush="#3498DB"/>

                <TextBlock Text="Generic Formula (Salt)" Margin="0,5,0,2"/>
                <TextBox x:Name="txtFormula" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center" Background="#FAFAFA"/>


                <TextBlock Text="Category" Margin="0,5,0,2"/>
                <TextBox x:Name="txtCategory" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                <TextBlock Text="Manufacturer" Margin="0,5,0,2"/>
                <TextBox x:Name="txtManufacturer" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="TP (Cost)" Margin="0,5,0,2"/>
                        <TextBox x:Name="txtPurchasePrice" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="2,0,2,0">
                        <TextBlock Text="WP (Wholesale)" Margin="0,5,0,2"/>
                        <TextBox x:Name="txtWholesalePrice" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center" Text="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="5,0,0,0">
                        <TextBlock Text="Retail (Sale)" Margin="0,5,0,2"/>
                        <TextBox x:Name="txtSalePrice" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <TextBlock Text="Minimum Stock Alert" Margin="0,5,0,2"/>
                <TextBox x:Name="txtMinStock" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center" Text="10"/>

                <!-- Batch No -->
                <TextBlock Text="Batch No" Margin="0,5,0,2"/>
                <TextBox x:Name="txtBatchNo" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center" Text="BATCH-001"/>

                <!-- Rack No -->
                <TextBlock Text="Rack No" Margin="0,5,0,2"/>
                <TextBox x:Name="txtRackNo" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center" Text="Rack-1"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Pack Size" Margin="0,5,0,2"/>
                        <TextBox x:Name="txtBoxSize" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center" Text="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Initial Stock" Margin="0,5,0,2"/>
                        <TextBox x:Name="txtInitialStock" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center" Text="0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnSave" Content="Save" Width="100" Height="35" Background="#27AE60" Foreground="White" BorderThickness="0" Margin="0,0,10,0" Click="SaveButton_Click" IsDefault="True"/>
            <Button x:Name="btnCancel" Content="Cancel" Width="90" Height="35" Background="#BDC3C7" Foreground="Black" BorderThickness="0" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
