<Window x:Class="PharmaBilling.Source.Views.AddStaffWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add New Staff Member" Height="540" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="#FAFAFA">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="txtTitle" Text="Staff Details" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
            <TextBlock Text="Fill in the details below to register a new staff member." FontSize="12" Foreground="#95A5A6" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Fields -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Row 1: Name + Designation -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Full Name *" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtName" Height="34" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#BDC3C7"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Designation / Role *" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtDesignation" Height="34" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#BDC3C7"/>
                    </StackPanel>
                </Grid>

                <!-- Row 2: Contact + CNIC -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Contact Number *" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtContact" Height="34" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#BDC3C7"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="CNIC (optional)" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtCNIC" Height="34" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#BDC3C7"/>
                    </StackPanel>
                </Grid>

                <!-- Row 3: Salary + Join Date -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Base Monthly Salary (Rs) *" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtBaseSalary" Height="34" Padding="10,0" VerticalContentAlignment="Center" BorderBrush="#BDC3C7"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Join Date" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                        <DatePicker x:Name="dpJoinDate" Height="34" SelectedDate="{x:Static sys:DateTime.Today}"
                                    xmlns:sys="clr-namespace:System;assembly=mscorlib"/>
                    </StackPanel>
                </Grid>

                <!-- Row 4: Address -->
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Address (optional)" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,4"/>
                    <TextBox x:Name="txtAddress" Height="60" Padding="10,8" TextWrapping="Wrap" AcceptsReturn="True" BorderBrush="#BDC3C7" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button x:Name="btnCancel" Content="Cancel" Width="100" Height="38" Background="#ECF0F1" Foreground="#2C3E50" BorderThickness="0" Margin="0,0,12,0" Click="CancelButton_Click" Cursor="Hand"/>
            <Button x:Name="btnSave" Content="✔  Save Staff" Width="130" Height="38" Background="#27AE60" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="SaveButton_Click" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
