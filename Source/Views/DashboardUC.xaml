<UserControl x:Class="PharmaBilling.Source.Views.DashboardUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="UserControl_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F1F4F8">
        <StackPanel Margin="24,20,24,30">

            <!-- ── HEADER ── -->
            <Grid Margin="0,0,0,16">
                <TextBlock Text="📊 Analytics Dashboard" FontSize="21" FontWeight="Bold"
                           Foreground="#1A1A2E" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="txtLastRefresh" Text="Last updated: —"
                               FontSize="11" Foreground="#9099A6" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button x:Name="btnRefresh" Content="⟳  Refresh"
                            Height="30" Width="100" Background="#3B82F6" Foreground="White"
                            BorderThickness="0" FontSize="12" Cursor="Hand"
                            Click="BtnRefresh_Click"/>
                </StackPanel>
            </Grid>

            <!-- ── KPI CARDS ── -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#EEF9F0" CornerRadius="10" Padding="16,12" Margin="0,0,8,0" BorderBrush="#C8E6C9" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="💰  Today's Sales" Foreground="#388E3C" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="lblDailySales" Text="Rs. 0" FontSize="24" FontWeight="Bold" Foreground="#1B5E20" Margin="0,4,0,2"/>
                        <TextBlock x:Name="lblSalesToday" Text="0 invoices" FontSize="11" Foreground="#66BB6A"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#EEF4FE" CornerRadius="10" Padding="16,12" Margin="4,0" BorderBrush="#BBDEFB" BorderThickness="1"
                        Cursor="Hand" MouseLeftButtonUp="TotalMedicines_Click">
                    <StackPanel>
                        <TextBlock Text="💊  Total Medicines" Foreground="#1565C0" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="lblTotalMedicines" Text="0" FontSize="24" FontWeight="Bold" Foreground="#0D47A1" Margin="0,4,0,2"/>
                        <TextBlock Text="in catalogue" FontSize="11" Foreground="#42A5F5"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#FFF8E1" CornerRadius="10" Padding="16,12" Margin="4,0" BorderBrush="#FFE082" BorderThickness="1"
                        Cursor="Hand" MouseLeftButtonUp="LowStock_Click">
                    <StackPanel>
                        <TextBlock Text="⚠️  Low Stock" Foreground="#E65100" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="lblLowStock" Text="0" FontSize="24" FontWeight="Bold" Foreground="#BF360C" Margin="0,4,0,2"/>
                        <TextBlock Text="below minimum" FontSize="11" Foreground="#FFA726"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3" Background="#FFF0F0" CornerRadius="10" Padding="16,12" Margin="8,0,0,0" BorderBrush="#FFCDD2" BorderThickness="1"
                        Cursor="Hand" MouseLeftButtonUp="ExpiredItems_Click">
                    <StackPanel>
                        <TextBlock Text="🚨  Expired" Foreground="#C62828" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock x:Name="lblExpiredItems" Text="0" FontSize="24" FontWeight="Bold" Foreground="#B71C1C" Margin="0,4,0,2"/>
                        <TextBlock Text="expiring within 30 days" FontSize="11" Foreground="#EF9A9A"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── ROW 2: Bar Chart + Donut ── -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*" MinWidth="220"/>
                </Grid.ColumnDefinitions>

                <!-- Bar Chart -->
                <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="16,14"
                        Margin="0,0,8,0" BorderBrush="#E8EAED" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📈  Sales – Last 7 Days" FontSize="14" FontWeight="Bold"
                                   Foreground="#1A1A2E" Margin="0,0,0,10"/>
                        <ItemsControl x:Name="barChart" Height="155">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="6,0">
                                        <TextBlock Text="{Binding AmountLabel}" FontSize="9" Foreground="#6B7280"
                                                   HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                        <Border Background="{Binding Color}" CornerRadius="3,3,0,0"
                                                Width="34" Height="{Binding BarHeight}"/>
                                        <TextBlock Text="{Binding DayLabel}" FontSize="10" Foreground="#6B7280"
                                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Stock Health -->
                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="16,14"
                        Margin="0" BorderBrush="#E8EAED" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="📦  Stock Health" FontSize="14" FontWeight="Bold"
                                   Foreground="#1A1A2E" Margin="0,0,0,10"/>
                        <Canvas x:Name="donutCanvas" Width="150" Height="150" HorizontalAlignment="Center"/>
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Rectangle Width="12" Height="12" Fill="#22C55E" RadiusX="2" RadiusY="2" Margin="0,0,7,0"/>
                                <TextBlock x:Name="lblInStock" Text="In Stock: 0" FontSize="12" Foreground="#374151"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Rectangle Width="12" Height="12" Fill="#F59E0B" RadiusX="2" RadiusY="2" Margin="0,0,7,0"/>
                                <TextBlock x:Name="lblLowStockLegend" Text="Low Stock: 0" FontSize="12" Foreground="#374151"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,3">
                                <Rectangle Width="12" Height="12" Fill="#EF4444" RadiusX="2" RadiusY="2" Margin="0,0,7,0"/>
                                <TextBlock x:Name="lblOutOfStock" Text="Out of Stock: 0" FontSize="12" Foreground="#374151"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ── ROW 3: Recent Sales ── -->
            <Grid>
                <Border Background="White" CornerRadius="10" Padding="16,14"
                        Margin="0" BorderBrush="#E8EAED" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="🧾  Recent Sales" FontSize="14" FontWeight="Bold" Foreground="#1A1A2E" Margin="0,0,0,8"/>
                        <DataGrid x:Name="gridRecentSales"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  BorderThickness="0" Background="White"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#F0F0F0"
                                  RowHeight="34" FontSize="12"
                                  AlternatingRowBackground="#FAFBFC"
                                  MaxHeight="190">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Invoice #" Binding="{Binding InvoiceNo}" Width="80"/>
                                <DataGridTextColumn Header="Customer"  Binding="{Binding Name}"      Width="*"/>
                                <DataGridTextColumn Header="Amount"    Binding="{Binding Amount}"    Width="110"/>
                                <DataGridTextColumn Header="Status"    Binding="{Binding Status}"    Width="75"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
