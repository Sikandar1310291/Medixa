<Window x:Class="PharmaBilling.Source.Views.AddPurchaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Purchase" Height="650" Width="1100" WindowStartupLocation="CenterOwner" Background="#F8F9FA"
        KeyDown="Window_KeyDown">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Top Header -->
        <Border Grid.Row="0" Background="White" Padding="15" BorderBrush="#EEE" BorderThickness="0,0,0,1">
            <TextBlock Text="NEW PURCHASE ENTRY" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
        </Border>

        <!-- Top Controls (Inv, Supplier, Date, Medicine Search) -->
        <Border Grid.Row="1" Background="White" Margin="15" Padding="15" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Invoice No." Foreground="#7F8C8D" Margin="0,0,0,5" />
                    <TextBox Text="{Binding InvoiceNo}" Padding="8" BorderThickness="1" BorderBrush="#DDD" />
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Text="Supplier" Foreground="#7F8C8D" Margin="0,0,0,5" />
                    <ComboBox x:Name="cboSupplier" ItemsSource="{Binding Suppliers}" SelectedItem="{Binding SelectedSupplier}" DisplayMemberPath="Name" IsEditable="True" Padding="8" BorderThickness="1" BorderBrush="#DDD"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Text="Date" Foreground="#7F8C8D" Margin="0,0,0,5" />
                    <DatePicker SelectedDate="{Binding PurchaseDate}" Padding="8" BorderThickness="1" BorderBrush="#DDD" />
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="Search &amp; Add Medicine" Foreground="#7F8C8D" Margin="0,0,0,5" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0" x:Name="cboMedicines" ItemsSource="{Binding FilteredMedicines}" DisplayMemberPath="Name" 
                                  IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" Padding="8" BorderThickness="1" 
                                  BorderBrush="#DDD" Margin="0,0,5,0" KeyUp="cboMedicines_KeyUp"
                                  VirtualizingStackPanel.IsVirtualizing="True" 
                                  VirtualizingStackPanel.VirtualizationMode="Recycling" />
                        <Button Grid.Column="1" Content="Add Item" Padding="15,8" Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="AddItem_Click"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Items Grid -->
        <Border Grid.Row="2" Background="White" Margin="15,0,15,0" Padding="10" CornerRadius="8">
            <DataGrid ItemsSource="{Binding PurchaseItems}" AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Medicine"              Binding="{Binding MedicineName}"                           IsReadOnly="True"  Width="2*"/>
                    
                    <!-- ── PACKS & PACK SIZE (Moved here for high visibility) ── -->
                    <DataGridTextColumn Header="Packs"     Binding="{Binding PacksStr,    UpdateSourceTrigger=LostFocus}" Width="0.7*">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Foreground" Value="#2980B9"/>
                                <Setter Property="FontWeight"  Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Pack Size" Binding="{Binding PackSizeStr, UpdateSourceTrigger=LostFocus}" Width="0.8*">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Foreground" Value="#8E44AD"/>
                                <Setter Property="FontWeight"  Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Qty" Binding="{Binding QuantityStr, UpdateSourceTrigger=LostFocus}" Width="0.8*">
                        <DataGridTextColumn.HeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Foreground" Value="#27AE60"/>
                                <Setter Property="FontWeight"  Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.HeaderStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Batch No"              Binding="{Binding BatchNo,    UpdateSourceTrigger=LostFocus}" Width="*"/>
                    <DataGridTextColumn Header="Rack No"               Binding="{Binding RackNo,     UpdateSourceTrigger=LostFocus}" Width="*"/>
                    <DataGridTextColumn Header="Expiry (YYYY-MM-DD)"   Binding="{Binding ExpiryDate, UpdateSourceTrigger=LostFocus}" Width="1.3*"/>
                    <DataGridTextColumn Header="TP"                    Binding="{Binding TPStr, UpdateSourceTrigger=LostFocus}" Width="*"/>
                    <DataGridTextColumn Header="Retail (Pack)"         Binding="{Binding RetailStr, UpdateSourceTrigger=LostFocus}" Width="*"/>
                    <DataGridTextColumn Header="Retail Qty"            Binding="{Binding RetailQtyStr, UpdateSourceTrigger=LostFocus}" Width="*"/>
                    <DataGridTextColumn Header="Total"                 Binding="{Binding TotalPrice}" IsReadOnly="True"                    Width="*"/>
                    <DataGridTemplateColumn Width="0.6*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" Background="#E74C3C" Foreground="White" FontWeight="Bold" Click="RemoveItem_Click" Padding="5"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Bottom Actions -->
        <Border Grid.Row="3" Background="White" Margin="15" Padding="15" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Pack size hint label -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Opacity="0.7">
                    <TextBlock Text="💡 Tip: " FontWeight="Bold" Foreground="#2C3E50" FontSize="12"/>
                    <TextBlock Text="Enter Packs + Pack Size → Qty auto-calculates (e.g. 2 packs × 10 = 20 units)" Foreground="#7F8C8D" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Gross Total: " FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="{Binding GrossTotal, StringFormat=Rs. {0:N2}}" FontSize="18" FontWeight="Bold" Foreground="#E74C3C"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Save Purchase (Enter)" Background="#2ECC71" Foreground="White" Padding="20,10" FontWeight="Bold" FontSize="14" BorderThickness="0" Cursor="Hand" Click="SavePurchase_Click" IsDefault="True"/>
            </Grid>
        </Border>
    </Grid>
</Window>
