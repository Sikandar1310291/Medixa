<Window x:Class="PharmaBilling.Source.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Medixa - Login" Height="450" Width="800"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Border CornerRadius="20" Background="White">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1.2*" />
            </Grid.ColumnDefinitions>

            <!-- Left Side: Branding/Image -->
            <Border Grid.Column="0" CornerRadius="20,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#0D47A1" Offset="0" />
                        <GradientStop Color="#1976D2" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Source/Images/logo.png" Width="60" Height="60" Stretch="Uniform" Margin="0,0,0,10"/>
                    <TextBlock Text="Medixa" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Billing &amp; Inventory Management" FontSize="14" Foreground="White" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Right Side: Login Form -->
            <Grid Grid.Column="1" Margin="40">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Login to your account" FontSize="24" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,30"/>
                    
                    <TextBlock Text="Username" Foreground="#666" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtUsername" Height="40" Padding="10,0" Margin="0,0,0,20" 
                             VerticalContentAlignment="Center" BorderBrush="#DDD" />

                    <TextBlock Text="Password" Foreground="#666" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPassword" Height="40" Padding="10,0" Margin="0,0,0,30" 
                                 VerticalContentAlignment="Center" BorderBrush="#DDD" />

                    <Button Content="Login" Height="45" Background="#1976D2" Foreground="White" 
                            FontSize="16" FontWeight="Bold" BorderThickness="0" Click="LoginButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <Button Content="Exit" Background="Transparent" BorderThickness="0" 
                                Foreground="#999" Margin="0,0,20,0" Click="ExitButton_Click" Cursor="Hand" />
                        <Button Content="Network Setup" Background="Transparent" BorderThickness="0" 
                                Foreground="#1976D2" Click="NetworkSetupButton_Click" Cursor="Hand" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
