<Window x:Class="PharmaBilling.Source.Views.PurchaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Purchase Entries" Height="500" Width="800" WindowStartupLocation="CenterScreen">
    <Grid Background="#F4F7F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" Padding="15" BorderBrush="#EEE" BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="PURCHASE ENTRIES" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+ Add Purchase" Background="#2ECC71" Foreground="White" BorderThickness="0" Padding="15,8" FontWeight="Bold" Cursor="Hand" Click="AddPurchase_Click" />
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="1" Margin="20" Background="White" CornerRadius="8" Padding="10">
            <DataGrid ItemsSource="{Binding PastPurchases}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Purchase ID" Width="80" Binding="{Binding PurchaseID}"/>
                    <DataGridTextColumn Header="Invoice #" Width="100" Binding="{Binding InvoiceNo}"/>
                    <DataGridTextColumn Header="Supplier" Width="*" Binding="{Binding SupplierName}"/>
                    <DataGridTextColumn Header="Date" Width="150" Binding="{Binding PurchaseDate}"/>
                    <DataGridTextColumn Header="Total Amount" Width="100" Binding="{Binding TotalAmount}"/>
                    <DataGridTextColumn Header="Status" Width="80" Binding="{Binding Status}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
