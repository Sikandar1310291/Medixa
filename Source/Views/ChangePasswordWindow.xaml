<Window x:Class="PharmaBilling.Source.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Password" Height="350" Width="400" WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow" ResizeMode="NoResize">
    <Grid Background="White">
        <StackPanel Margin="30">
            <TextBlock Text="Change Password" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            
            <TextBlock Text="Current Password" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtCurrentPass" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center"/>
            
            <TextBlock Text="New Password" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtNewPass" Height="35" Margin="0,0,0,15" VerticalContentAlignment="Center"/>
            
            <TextBlock Text="Confirm Password" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtConfirmPass" Height="35" Margin="0,0,0,25" VerticalContentAlignment="Center"/>
            
            <Button x:Name="btnSave" Content="Save Password" Height="40" Background="#1976D2" Foreground="White" FontWeight="Bold" Click="btnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
