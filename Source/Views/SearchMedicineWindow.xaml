<Window x:Class="PharmaBilling.Source.Views.SearchMedicineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find" Height="600" Width="900" 
        WindowStartupLocation="CenterScreen" 
        ResizeMode="NoResize"
        Background="#F0F0F0">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Search Bar -->
        <Border Grid.Row="0" Margin="0,0,0,10" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Find" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <TextBox x:Name="txtSearch" Width="400" Height="25" TextChanged="txtSearch_TextChanged" PreviewKeyDown="txtSearch_KeyDown"/>
            </StackPanel>
        </Border>

        <!-- Data Grid -->
        <DataGrid x:Name="dgMedicines" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                  SelectionMode="Single" MouseDoubleClick="dgMedicines_MouseDoubleClick" PreviewKeyDown="dgMedicines_KeyDown"
                  Background="White" RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Item Name" Binding="{Binding Name}" Width="250"/>
                <DataGridTextColumn Header="Item ID" Binding="{Binding MedicineID}" Width="80"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="120"/>
                <DataGridTextColumn Header="UOM" Binding="{Binding Unit}" Width="60"/>
                <DataGridTextColumn Header="Stock" Binding="{Binding TotalStock}" Width="60"/>
                <DataGridTextColumn Header="Unit Price" Binding="{Binding SalePrice}" Width="80"/>
                <DataGridTextColumn Header="P.Price" Binding="{Binding PurchasePrice}" Width="80"/>
                <DataGridTextColumn Header="S.Price" Binding="{Binding SalePrice}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Find" Width="80" Height="25" Margin="0,0,10,0" Click="btnFind_Click"/>
            <Button Content="OK" Width="80" Height="25" Margin="0,0,10,0" Click="btnOK_Click" IsDefault="True"/>
            <Button Content="Cancel" Width="80" Height="25" Click="btnCancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
