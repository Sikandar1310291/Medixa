<UserControl x:Class="PharmaBilling.Source.Views.AccountingUC"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Color="#000000" Opacity="0.05" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F4F7F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="White" Padding="15" BorderBrush="#EEE" BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="ACCOUNTING &amp; LEDGERS" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Refresh"   Background="#3498DB" Foreground="White" BorderThickness="0" Click="Refresh_Click" Cursor="Hand" Margin="0,0,10,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Statistics Section -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Margin="10">

                <!-- Today Card -->
                <Border Style="{StaticResource StatCard}" >
                    <StackPanel>
                        <TextBlock Text="TODAY" FontWeight="Bold" Foreground="#1ABC9C" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Total Sales" Style="{StaticResource StatLabel}"/>
                                <TextBlock Text="{Binding TodaySales}" Style="{StaticResource StatValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                <TextBlock Text="Total Purchases" Style="{StaticResource StatLabel}"/>
                                <TextBlock Text="{Binding TodayPurchases}" Style="{StaticResource StatValue}"/>
                            </StackPanel>


                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- This Week Card -->
                <Border Style="{StaticResource StatCard}" >
                    <StackPanel>
                        <TextBlock Text="THIS WEEK (7 DAYS)" FontWeight="Bold" Foreground="#3498DB" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            
                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Total Sales" Style="{StaticResource StatLabel}"/>
                                <TextBlock Text="{Binding WeekSales}" Style="{StaticResource StatValue}"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                <TextBlock Text="Total Purchases" Style="{StaticResource StatLabel}"/>
                                <TextBlock Text="{Binding WeekPurchases}" Style="{StaticResource StatValue}"/>
                            </StackPanel>


                        </Grid>
                    </StackPanel>
                </Border>

                <!-- This Month Card -->
                <Border Style="{StaticResource StatCard}" >
                    <StackPanel>
                        <TextBlock Text="THIS MONTH (30 DAYS)" FontWeight="Bold" Foreground="#9B59B6" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Total Sales" Style="{StaticResource StatLabel}"/>
                                <TextBlock Text="{Binding MonthSales}" Style="{StaticResource StatValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                <TextBlock Text="Total Purchases" Style="{StaticResource StatLabel}"/>
                                <TextBlock Text="{Binding MonthPurchases}" Style="{StaticResource StatValue}"/>
                            </StackPanel>


                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 12 Month Card -->
                <Border Style="{StaticResource StatCard}" >
                    <StackPanel>
                        <TextBlock Text="LAST 12 MONTHS" FontWeight="Bold" Foreground="#E67E22" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Total Sales" Style="{StaticResource StatLabel}"/>
                                <TextBlock Text="{Binding YearSales}" Style="{StaticResource StatValue}"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                <TextBlock Text="Total Purchases" Style="{StaticResource StatLabel}"/>
                                <TextBlock Text="{Binding YearPurchases}" Style="{StaticResource StatValue}"/>
                            </StackPanel>


                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="2" Margin="20,0,20,20" Background="White" CornerRadius="8" Padding="10">
            <DataGrid x:Name="dgLedgers" ItemsSource="{Binding Ledgers}" SelectedItem="{Binding SelectedLedger}" AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="Horizontal" Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ledger Name"  Binding="{Binding Name}"/>
                    <DataGridTextColumn Header="Type"  Binding="{Binding Type}"/>
                    <DataGridTextColumn Header="Current Balance"  Binding="{Binding Balance, StringFormat='Rs. {0:N2}'}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
