<UserControl x:Class="PharmaBilling.Source.Views.BackupUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            
            <!-- Header with Status Badge -->
            <Grid Margin="0,0,0,25">
                <StackPanel>
                    <TextBlock Text="Database Backup" FontSize="24" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBlock Text="Google-grade Continuous Data Protection (CDP) is enabled. Your data is automatically mirrored across PC, USB, and Cloud every 60 minutes." 
                               Foreground="#7F8C8D" FontSize="13" TextWrapping="Wrap" MaxWidth="600" HorizontalAlignment="Left"/>
                </StackPanel>
                
                <Border Background="#27AE60" CornerRadius="15" Padding="12,5" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#FFF" Margin="0,0,8,0">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:1" AutoReverse="True"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock Text="AUTO-CDP: ACTIVE" Foreground="White" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Status Cards -->
            <UniformGrid Columns="3" Margin="0,0,0,25">
                <Border Background="#EAF6FF" CornerRadius="10" Margin="0,0,10,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📅 Last Backup" Foreground="#3498DB" FontWeight="Bold" FontSize="13"/>
                        <TextBlock x:Name="txtLastBackup" Text="Checking..." FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#EAFAF1" CornerRadius="10" Margin="10,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="💾 Total Snapshots" Foreground="#27AE60" FontWeight="Bold" FontSize="13"/>
                        <TextBlock x:Name="txtTotalBackups" Text="Checking..." FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#FEF9E7" CornerRadius="10" Margin="10,0,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📂 Backup Location" Foreground="#E67E22" FontWeight="Bold" FontSize="13"/>
                        <TextBlock x:Name="txtBackupPath" Text="Checking..." FontSize="11" Foreground="#2C3E50" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                <Button x:Name="btnBackupNow" Content="🔄  Backup Now" Width="160" Height="42" 
                        Background="#3498DB" Foreground="White" FontWeight="Bold" FontSize="14"
                        BorderThickness="0" Cursor="Hand" Click="BtnBackupNow_Click" Margin="0,0,12,0"
                        ToolTip="Create a manual backup right now"/>
                <Button x:Name="btnOpenFolder" Content="📁  Open Backup Folder" Width="190" Height="42" 
                        Background="#27AE60" Foreground="White" FontWeight="Bold" FontSize="14"
                        BorderThickness="0" Cursor="Hand" Click="BtnOpenFolder_Click"
                        ToolTip="View all backup files on disk"/>
            </StackPanel>

            <!-- Backup List Grid -->
            <TextBlock Text="Backup History (Last 30)" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <Border Background="White" CornerRadius="8" Padding="10">
                <DataGrid x:Name="dgBackups" AutoGenerateColumns="False" IsReadOnly="True"
                          BorderThickness="0" Background="White" GridLinesVisibility="Horizontal"
                          MaxHeight="400">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Backup Date" Binding="{Binding Date}" Width="180"/>
                        <DataGridTextColumn Header="File Name" Binding="{Binding FileName}" Width="*"/>
                        <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="120"/>
                        <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Info Box -->
            <Border Background="#F8F9FA" CornerRadius="8" Padding="15" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="ℹ️  How it Works" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#555" LineHeight="22">
                        • <Bold>Automatic Daily Backup:</Bold> Every time Medixa opens, it silently backs up your entire database in the background.&#x0a;
                        • <Bold>1 Year Retention:</Bold> 365 daily snapshots are kept. Older files are auto-deleted to save disk space.&#x0a;
                        • <Bold>Dual Redundancy:</Bold> Backup is saved both in your app folder AND on any secondary drive (D:\ or E:\) if available.&#x0a;
                        • <Bold>Crash-Safe:</Bold> Uses the SQLite Online Backup API — same technology used by Google Firebase.
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
