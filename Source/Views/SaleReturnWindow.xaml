<Window x:Class="PharmaBilling.Source.Views.SaleReturnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sale Return" Height="600" Width="1000"
        WindowStartupLocation="CenterOwner" Background="#F8F9FA">

    <Window.Resources>
        <Style x:Key="LblStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7F8C8D"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#E67E22" Padding="18,14">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="↩" FontSize="20" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="SALE RETURN" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="Accept returned goods from customer and restore stock" FontSize="11" Foreground="#FDEBD0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Controls -->
        <Border Grid.Row="1" Background="White" Margin="15,15,15,8" Padding="18" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="Select Sale Invoice" Style="{StaticResource LblStyle}"/>
                    <ComboBox x:Name="cboSale" ItemsSource="{Binding AllSales}"
                              SelectedItem="{Binding SelectedSale}"
                              DisplayMemberPath="Display"
                              IsEditable="True" Padding="8" BorderBrush="#DDD" BorderThickness="1" FontSize="12"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="Return Date" Style="{StaticResource LblStyle}"/>
                    <DatePicker x:Name="dpReturnDate" SelectedDate="{x:Static system:DateTime.Now}"
                                xmlns:system="clr-namespace:System;assembly=mscorlib"
                                Padding="8" BorderBrush="#DDD" BorderThickness="1"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Reason for Return" Style="{StaticResource LblStyle}"/>
                    <TextBox Text="{Binding Reason}" Padding="8" BorderBrush="#DDD" BorderThickness="1"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Items Grid -->
        <Border Grid.Row="2" Background="White" Margin="15,0,15,8" Padding="12" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="🛒  Items from Selected Sale — Enter Return Qty for each item to return"
                           FontSize="12" Foreground="#555" Margin="0,0,0,8" FontStyle="Italic"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding ReturnItems}" AutoGenerateColumns="False"
                          CanUserAddRows="False" GridLinesVisibility="Horizontal"
                          Background="White" BorderBrush="#EEE" BorderThickness="1"
                          RowHeaderWidth="0" AlternatingRowBackground="#FAFAFA">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Medicine" Binding="{Binding MedicineName}" IsReadOnly="True" Width="2.5*"/>
                        <DataGridTextColumn Header="Batch No" Binding="{Binding BatchNo}" IsReadOnly="True" Width="*"/>
                        <DataGridTextColumn Header="Sold Qty" Binding="{Binding SoldQty}" IsReadOnly="True" Width="*">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Foreground" Value="#2980B9"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Return Qty" Binding="{Binding ReturnQty, UpdateSourceTrigger=PropertyChanged}" Width="*">
                            <DataGridTextColumn.HeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Foreground" Value="#E67E22"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.HeaderStyle>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#E67E22"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Sale Price" Binding="{Binding UnitPrice, StringFormat=N2}" IsReadOnly="True" Width="*"/>
                        <DataGridTextColumn Header="Refund Amount" Binding="{Binding TotalPrice, StringFormat=Rs. \{0:N2\}}" IsReadOnly="True" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Foreground" Value="#27AE60"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Background="White" Margin="15,0,15,15" Padding="18,14" CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⚠ " Foreground="#E67E22" FontSize="14"/>
                    <TextBlock Text="Stock will be restored to inventory. Cash refund will be deducted from ledger." 
                               Foreground="#7F8C8D" FontSize="11" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="Total Refund: " FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat=Rs. \{0:N2\}}"
                               FontSize="16" FontWeight="Bold" Foreground="#E67E22"/>
                </StackPanel>

                <Button Grid.Column="2" Content="Cancel" Width="90" Margin="0,0,10,0"
                        Background="#ECF0F1" Foreground="#2C3E50" Style="{StaticResource ActionBtn}"
                        Click="Cancel_Click"/>
                <Button Grid.Column="3" Content="✔ Process Return" Background="#E67E22" Foreground="White"
                        Style="{StaticResource ActionBtn}" Click="SaveReturn_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
